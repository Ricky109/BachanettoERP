{
  "name": "bachanetto-erp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
 "scripts": {
  "dev":       "concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
  "dev:api":   "npm run dev --workspace=apps/api",
  "dev:web":   "npm run dev --workspace=apps/web",
  "build":     "npm run build --workspace=packages/shared && npm run build --workspace=apps/api",
  "build:web": "npm run build --workspace=apps/web"
},
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "concurrently": "^8.2.2",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1"
  }
}
