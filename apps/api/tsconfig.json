{
  "compilerOptions": {
    "target":                           "ES2022",
    "module":                           "commonjs",
    "rootDir":                          "./src",
    "outDir":                           "./dist",
    "esModuleInterop":                  true,
    "forceConsistentCasingInFileNames": true,
    "strict":                           true,
    "skipLibCheck":                     true,
    "resolveJsonModule":                true,
    "types":                            ["node"],
    "paths": {
      "@bachanetto/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}